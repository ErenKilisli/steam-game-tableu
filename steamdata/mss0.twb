      </column>
      <column caption='Primary Genre' datatype='string' name='[Calculation_4781440714526721]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='TRIM(SPLIT([Genres], &quot;,&quot;, 1))' />
      </column>
      <column caption='Success @ 1 Platform' datatype='real' name='[Calculation_4781440725303298]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(IF [platform_count] = 1 THEN [success] END)' />
      </column>
      <column caption='Success @ 3 Platforms' datatype='real' name='[Calculation_4781440725389315]' role='measure' type='quantitative'>
